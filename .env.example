# Mandatory
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-telegram-token
LLM_API_KEY=replace-with-your-llm-api-key
LLM_MODEL=gpt-5.4-mini
LLM_BASE_URL=
# Not mandatory
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-shared-secret
TELEGRAM_WEBHOOK_URL=https://your-public-domain.example.com/telegram/webhook
TELEGRAM_POLL_TIMEOUT_SECONDS=20
TELEGRAM_SEND_RETRIES=3
TELEGRAM_WORKER_COUNT=4
SESSION_TIMEOUT_MINUTES=30


DATABASE_URL=sqlite:///data/fridgemate.db
SQL_ECHO=0
SEED_HISTORY_ON_STARTUP=1
SEED_HISTORY_DAYS=180
SEED_HISTORY_SEED=4052
MEMORY_STORE_PATH=data/fridge_memory.json
LOG_STORE_PATH=data/runtime_logs.json
TRACE_MODE=0
TRACE_LOG_PATH=data/traces


LLM_GATEWAY_POLICY_PATH=config/llm_gateway_policy.json
